# --- Server ---
NODE_ENV=development
PORT=4000

# --- Database ---
# MongoDB Atlas connection string. See docs/deployment.md for cluster setup.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/certifychain

# --- Auth ---
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=replace_with_64_char_hex_secret
JWT_REFRESH_SECRET=replace_with_a_different_64_char_hex_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- CORS ---
CLIENT_URL=http://localhost:5173

# --- Stellar / Soroban ---
STELLAR_NETWORK=TESTNET
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org
CONTRACT_ID=PLACEHOLDER_CONTRACT_ID_AFTER_DEPLOYMENT

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Monitoring ---
SENTRY_DSN=

# --- Misc ---
ADMIN_EMAIL=admin@example.com
LOG_LEVEL=info
